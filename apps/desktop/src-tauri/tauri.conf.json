{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SyncMind",
  "identifier": "com.blkcor.syncmind",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "width": 860,
        "height": 540,
        "resizable": false,
        "decorations": false,
        "center": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "global-shortcut": {},
    "autostart": {},
    "shell": {},
    "dialog": {}
  }
}
