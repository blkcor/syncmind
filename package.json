{
  "name": "syncmind",
  "private": true,
  "version": "0.0.0",
  "description": "Privacy-first, fully offline proactive local context engine",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @syncmind/desktop tauri build",
    "dev": "pnpm -r dev",
    "dev:desktop": "pnpm --filter @syncmind/desktop tauri dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
